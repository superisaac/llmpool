{
  "openapi": "3.0.3",
  "info": {
    "title": "LLMPool Admin API",
    "version": "1.0.0",
    "description": "Admin REST API for managing LLMPool resources: upstreams, models, accounts, API keys, wallets, session events, subscription plans, and subscriptions."
  },
  "servers": [
    {
      "url": "http://localhost:19324/api/v1",
      "description": "Local development server"
    }
  ],
  "security": [
    { "AdminToken": [] }
  ],
  "components": {
    "securitySchemes": {
      "AdminToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-admin-token",
        "description": "Admin JWT token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["error", "message"]
      },
      "PaginationInfo": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "page_size": { "type": "integer" },
          "total": { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "WalletResponse": {
        "type": "object",
        "description": "Account wallet containing the current balance. Balance can be negative (indicating debt).",
        "properties": {
          "id": { "type": "integer" },
          "account_id": { "type": "integer" },
          "balance": { "type": "string", "description": "Current balance as a decimal string. Can be negative (debt)." },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ApiCredentialResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "account_id": { "type": "integer", "nullable": true },
          "apikey": { "type": "string", "description": "Ellipsed API key (e.g. lpx-ab...cd)" },
          "label": { "type": "string" },
          "is_active": { "type": "boolean" },
          "expires_at": { "type": "string", "format": "date-time", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ApiCredentialCreatedResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiCredentialResponse" },
          {
            "type": "object",
            "properties": {
              "apikey": { "type": "string", "description": "Full plaintext API key (only returned on creation)" },
              "ellipsed_apikey": { "type": "string" }
            }
          }
        ]
      },
      "UpstreamResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "api_base": { "type": "string" },
          "provider": { "type": "string" },
          "has_responses_api": { "type": "boolean" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "proxies": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["online", "offline", "maintenance"] },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ModelResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "upstream_id": { "type": "integer" },
          "model_id": { "type": "string" },
          "is_active": { "type": "boolean" },
          "has_chat_completion": { "type": "boolean" },
          "has_embedding": { "type": "boolean" },
          "has_image_generation": { "type": "boolean" },
          "has_speech": { "type": "boolean" },
          "input_token_price": { "type": "string" },
          "output_token_price": { "type": "string" },
          "batch_input_token_price": { "type": "string" },
          "batch_output_token_price": { "type": "string" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "BalanceChangeResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "account_id": { "type": "integer" },
          "unique_request_id": { "type": "string" },
          "content": { "type": "object", "description": "JSON content describing the balance change (type, amount, tokens, etc.)" },
          "is_applied": { "type": "boolean" },
          "subscription_id": { "type": "integer", "description": "ID of the subscription used for this change (0 if none)" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "SessionEventResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "session_id": { "type": "string" },
          "session_index": { "type": "integer" },
          "account_id": { "type": "integer" },
          "model_id": { "type": "integer" },
          "api_key_id": { "type": "integer" },
          "input_token_price": { "type": "string" },
          "input_tokens": { "type": "integer" },
          "output_token_price": { "type": "string" },
          "output_tokens": { "type": "integer" },
          "event_data": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "SubscriptionPlanResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": {
            "type": "string",
            "enum": ["active", "deactive"]
          },
          "description": { "type": "string" },
          "total_token_limit": { "type": "integer", "description": "0 means unlimited" },
          "time_span": { "type": "integer", "description": "Time span in seconds; 0 means unlimited" },
          "money_limit": { "type": "string", "description": "Decimal string; 0 means unlimited" },
          "sort_order": { "type": "integer", "description": "Higher value = higher priority" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "account_id": { "type": "integer" },
          "plan_id": { "type": "integer" },
          "status": {
            "type": "string",
            "enum": ["active", "deactive"]
          },
          "start_at": { "type": "string", "format": "date-time", "nullable": true },
          "end_at": { "type": "string", "format": "date-time", "nullable": true },
          "used_total_tokens": { "type": "integer" },
          "total_token_limit": { "type": "integer", "description": "0 means unlimited" },
          "sort_order": { "type": "integer" },
          "used_money": { "type": "string", "description": "Decimal string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "TagsResponse": {
        "type": "object",
        "properties": {
          "upstream_id": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "UpstreamWithModelsResponse": {
        "type": "object",
        "properties": {
          "upstream": { "$ref": "#/components/schemas/UpstreamResponse" },
          "models": { "type": "array", "items": { "$ref": "#/components/schemas/ModelResponse" } }
        }
      }
    }
  },
  "paths": {
    "/accounts": {
      "get": {
        "summary": "List accounts",
        "operationId": "listAccounts",
        "tags": ["Accounts"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/AccountResponse" } },
                    "pagination": { "$ref": "#/components/schemas/PaginationInfo" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create account",
        "operationId": "createAccount",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } } },
          "409": { "description": "Duplicate name", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/accounts/{account_id}": {
      "get": {
        "summary": "Get account by ID",
        "operationId": "getAccount",
        "tags": ["Accounts"],
        "parameters": [{ "name": "account_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Account", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "summary": "Update account",
        "operationId": "updateAccount",
        "tags": ["Accounts"],
        "parameters": [{ "name": "account_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated account", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/accounts_by_name/{name}": {
      "get": {
        "summary": "Get account by name",
        "operationId": "getAccountByName",
        "tags": ["Accounts"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Account", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/accounts/{account_id}/wallet": {
      "get": {
        "summary": "Get account wallet",
        "description": "Returns the wallet (balance) for the given account. If no wallet record exists yet, returns a default wallet with zero balance.",
        "operationId": "getAccountWallet",
        "tags": ["Wallets"],
        "parameters": [{ "name": "account_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Wallet", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WalletResponse" } } } },
          "404": { "description": "Account not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/accounts/{account_id}/apikeys": {
      "get": {
        "summary": "List API keys for account",
        "operationId": "listAccountApikeys",
        "tags": ["API Keys"],
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/ApiCredentialResponse" } },
                    "pagination": { "$ref": "#/components/schemas/PaginationInfo" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create API key for account",
        "operationId": "createAccountApikey",
        "tags": ["API Keys"],
        "parameters": [{ "name": "account_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "label": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "API key created (includes full plaintext key)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiCredentialCreatedResponse" } } } }
        }
      }
    },
    "/apikeys/{apikey}": {
      "get": {
        "summary": "Get API key info",
        "operationId": "getApikey",
        "tags": ["API Keys"],
        "parameters": [{ "name": "apikey", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "API key info", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiCredentialResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "summary": "Deactivate API key",
        "operationId": "deleteApikey",
        "tags": ["API Keys"],
        "parameters": [{ "name": "apikey", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "API key deactivated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiCredentialResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/deposits": {
      "post": {
        "summary": "Create deposit",
        "description": "Adds to the account's wallet balance.",
        "operationId": "createDeposit",
        "tags": ["Wallets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account_id": { "type": "integer" },
                  "unique_request_id": { "type": "string", "description": "Client-provided idempotency key" },
                  "amount": { "type": "string", "description": "Positive decimal amount" }
                },
                "required": ["account_id", "unique_request_id", "amount"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Deposit created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceChangeResponse" } } } }
        }
      }
    },
    "/withdrawals": {
      "post": {
        "summary": "Create withdrawal",
        "description": "Deducts from the account's wallet balance.",
        "operationId": "createWithdrawal",
        "tags": ["Wallets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account_id": { "type": "integer" },
                  "unique_request_id": { "type": "string", "description": "Client-provided idempotency key" },
                  "amount": { "type": "string", "description": "Positive decimal amount" }
                },
                "required": ["account_id", "unique_request_id", "amount"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Withdrawal created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceChangeResponse" } } } }
        }
      }
    },
    "/credits": {
      "post": {
        "summary": "Create credit",
        "description": "Adds credit to the account's wallet balance (treated the same as a deposit).",
        "operationId": "createCredit",
        "tags": ["Wallets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account_id": { "type": "integer" },
                  "unique_request_id": { "type": "string", "description": "Client-provided idempotency key" },
                  "amount": { "type": "string", "description": "Positive decimal amount" }
                },
                "required": ["account_id", "unique_request_id", "amount"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Credit created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceChangeResponse" } } } }
        }
      }
    },
    "/upstreams": {
      "get": {
        "summary": "List upstreams",
        "operationId": "listUpstreams",
        "tags": ["Upstreams"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of upstreams",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/UpstreamResponse" } },
                    "pagination": { "$ref": "#/components/schemas/PaginationInfo" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create upstream",
        "description": "Creates a new upstream. Auto-detects available models and saves them to the database.",
        "operationId": "createUpstream",
        "tags": ["Upstreams"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "api_key": { "type": "string" },
                  "api_base": { "type": "string" },
                  "provider": { "type": "string", "default": "openai" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "proxies": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["name", "api_key", "api_base"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upstream created with models",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpstreamWithModelsResponse" }
              }
            }
          }
        }
      }
    },
    "/upstreams/{upstream_id}": {
      "get": {
        "summary": "Get upstream by ID",
        "operationId": "getUpstream",
        "tags": ["Upstreams"],
        "parameters": [{ "name": "upstream_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Upstream", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpstreamResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "summary": "Update upstream",
        "operationId": "updateUpstream",
        "tags": ["Upstreams"],
        "parameters": [{ "name": "upstream_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "provider": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "proxies": { "type": "array", "items": { "type": "string" } },
                  "description": { "type": "string" },
                  "status": { "type": "string", "enum": ["online", "offline", "maintenance"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated upstream", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpstreamResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/upstream_by_name/{name}": {
      "get": {
        "summary": "Get upstream by name",
        "operationId": "getUpstreamByName",
        "tags": ["Upstreams"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Upstream", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpstreamResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/upstreams/{upstream_id}/tags": {
      "get": {
        "summary": "List upstream tags",
        "operationId": "listUpstreamTags",
        "tags": ["Upstreams"],
        "parameters": [{ "name": "upstream_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Tags", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TagsResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "summary": "Add tag to upstream",
        "operationId": "addUpstreamTag",
        "tags": ["Upstreams"],
        "parameters": [{ "name": "upstream_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "tag": { "type": "string" } },
                "required": ["tag"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated tags", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TagsResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/upstreams/{upstream_id}/tags/{tag}": {
      "delete": {
        "summary": "Remove tag from upstream",
        "operationId": "removeUpstreamTag",
        "tags": ["Upstreams"],
        "parameters": [
          { "name": "upstream_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "tag", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Updated tags", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TagsResponse" } } } },
