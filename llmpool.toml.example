# LLMPool Configuration File
# Copy this file to llmpool.toml and adjust the values.

[database]
# PostgreSQL connection URL
url = "postgres://user:password@localhost/llmpool"

[admin]
# JWT secret for authenticating admin API requests
jwt_secret = "your-jwt-secret-here"

[redis]
# Redis connection URL for task queue
# Can also be set via REDIS_URL environment variable (takes priority)
url = "redis://127.0.0.1:6379"

[security]
# Hex-encoded 256-bit (32-byte) key for AES-256-GCM encryption of sensitive fields
# (e.g., OpenAI endpoint API keys stored in the database).
# Generate a key with: openssl rand -hex 32
# If left empty, API keys will be stored in plaintext (not recommended for production).
encryption_key = ""

[rate_limit]
# Whether rate limiting is enabled for /openai/v1 routes (default: false)
enabled = false

# IP-based rate limiting: maximum requests per window per client IP address
ip_requests = 100
ip_window_secs = 60

# Token-based rate limiting: maximum requests per window per Authorization token
# (keyed on a SHA-256 hash of the Bearer token value)
token_requests = 200
token_window_secs = 60
